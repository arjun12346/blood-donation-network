{
  "name": "blood-donation-mobile",
  "version": "1.0.0",
  "description": "Blood Donation Network - Mobile App for iOS and Android",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eject": "expo eject",
    "test": "jest",
    "lint": "eslint ."
  },
  "dependencies": {
    "react": "18.2.0",
    "react-native": "0.73.6",
    "expo": "^50.0.0",
    "expo-status-bar": "~1.11.0",
    "expo-splash-screen": "~0.26.0",
    "expo-font": "~11.10.0",
    "expo-location": "~16.5.0",
    "expo-notifications": "~0.27.0",
    "expo-document-picker": "~11.10.0",
    "expo-image-picker": "~14.7.0",
    "expo-web-browser": "~12.8.0",
    "react-native-screens": "~3.27.0",
    "react-native-safe-area-context": "^4.8.0",
    "react-native-gesture-handler": "~2.14.0",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/bottom-tabs": "^6.5.10",
    "@react-navigation/stack": "^6.3.17",
    "@react-navigation/native-stack": "^6.9.13",
    "axios": "^1.6.0",
    "socket.io-client": "^4.7.2",
    "react-native-toast-message": "^2.1.5",
    "react-native-maps": "1.10.0",
    "react-native-svg": "14.1.0",
    "expo-auth-session": "~5.4.0",
    "@react-native-async-storage/async-storage": "^1.21.0",
    "react-native-dotenv": "^3.4.0",
    "jotai": "^2.7.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.23.0",
    "@babel/preset-typescript": "^7.23.0",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.73.0",
    "babel-plugin-module-resolver": "^5.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^50.0.0",
    "@react-native-community/eslint-config": "^3.2.0",
    "eslint": "^8.55.0"
  },
  "private": true,
  "expo": {
    "name": "BloodNet Mobile",
    "slug": "bloodnet-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.bloodnet.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.bloodnet.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow BloodNet to access your location"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#ffffff",
          "sounds": [
            "./assets/notification-sound.wav"
          ]
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow BloodNet to access your photos",
          "cameraPermission": "Allow BloodNet to access your camera"
        }
      ]
    ],
    "scheme": "bloodnet",
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
