# ============================================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================================

# NODE ENVIRONMENT
NODE_ENV=production
PORT=5000

# DATABASE
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/blood-donation-prod

# JWT & SECURITY
JWT_SECRET=your-super-secret-jwt-key-here-change-in-production
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key

# SMS & OTP (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_VERIFY_SERVICE_SID=your-verify-service-sid

# EMAIL (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@blooddonationnetwork.com
SENDGRID_FROM_NAME=Blood Donation Network

# PHONE CALLS (Twilio Voice)
TWILIO_VOICE_WEBHOOK_URL=https://yourapi.com/api/voice/webhook

# PAYMENT (Stripe or Razorpay)
STRIPE_SECRET_KEY=sk_live_your-stripe-key
STRIPE_PUBLIC_KEY=pk_live_your-stripe-public-key
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
PAYMENT_PROVIDER=stripe

# GEOLOCATION & MAPS
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_MAPS_CLIENT_ID=your-google-maps-client-id

# KYC & IDENTITY VERIFICATION
KYC_PROVIDER=aadhar_sdk
AADHAR_API_KEY=your-aadhar-api-key
TRULIOO_API_KEY=your-trulioo-api-key
TRULIOO_SANDBOX_KEY=your-trulioo-sandbox-key

# AWS S3 (for document storage)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=blood-donation-documents
AWS_S3_REGION=us-east-1

# BLOOD BANK & HOSPITAL APIs
BLOOD_BANK_API_KEY=your-blood-bank-api-key
HOSPITAL_API_KEY=your-hospital-api-key

# EMERGENCY SERVICES
EMERGENCY_SERVICES_API_KEY=your-emergency-api-key

# FRAUD DETECTION & ML
ML_API_ENDPOINT=https://ml-api.blooddonationnetwork.com
ML_API_KEY=your-ml-api-key
FRAUD_DETECTION_THRESHOLD=0.75

# MONITORING & LOGGING
SENTRY_DSN=your-sentry-dsn
LOG_LEVEL=info
LOGSTASH_HOST=localhost
LOGSTASH_PORT=5000

# REDIS (for caching & sessions)
REDIS_URL=redis://:password@localhost:6379

# CLIENT URLs
CLIENT_URL=https://blooddonationnetwork.com
ANDROID_APP_URL=https://play.google.com/store/apps/details?id=com.bloodnet
IOS_APP_URL=https://apps.apple.com/app/blood-donation-network/id123456789

# RATE LIMITING
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
AUTH_RATE_LIMIT_MAX=30
API_RATE_LIMIT_MAX=100

# FEATURE FLAGS
ENABLE_KYC=true
ENABLE_PAYMENTS=true
ENABLE_PHONE_CALLS=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_FRAUD_DETECTION=true
ENABLE_ML_SCORING=true

# DONATION RULES
DONATION_EXPIRY_HOURS=48
MINIMUM_DONATION_INTERVAL_DAYS=56
DONOR_AGE_MIN=18
DONOR_AGE_MAX=65
DONOR_WEIGHT_MIN_KG=50

# REGION SETTINGS (for global support)
DEFAULT_COUNTRY=US
DEFAULT_TIMEZONE=UTC
SUPPORTED_COUNTRIES=US,UK,India,Canada,Australia,Germany,France,Japan,Singapore

# NOTIFICATION SETTINGS
NOTIFICATION_RETENTION_DAYS=30
EMAIL_VERIFICATION_EXPIRY_HOURS=24
OTP_EXPIRY_MINUTES=10

# ADMIN SETTINGS
ADMIN_EMAIL=admin@blooddonationnetwork.com
ADMIN_PHONE=+1234567890
SUPPORT_EMAIL=support@blooddonationnetwork.com
SUPPORT_PHONE=+1234567890

# VERSION INFO
APP_VERSION=1.0.0
API_VERSION=v1
